{
  "expo": {
    "name": "Kihap",
    "slug": "kihap",
    "owner": "kihap",
    "version": "3.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "native",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kihap.app",
      "buildNumber": "24"
    },
    "android": {
      "package": "com.kihap.app",
      "versionCode": 24,
      "adaptiveIcon": {
        "backgroundColor": "#eab308",
        "foregroundImage": "./assets/images/android-foreground-safe.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "meta": {
        "viewport": "width=device-width, initial-scale=1, viewport-fit=cover"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon_transparent.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#eab308",
          "dark": {
            "backgroundColor": "#eab308"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f27cb7d8-47f7-4d06-93fb-9a51d0303949"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f27cb7d8-47f7-4d06-93fb-9a51d0303949"
    }
  }
}
