{
  "expo": {
    "name": "Kihap",
    "slug": "kihap",
    "version": "2.6.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "native",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kihap.app",
      "buildNumber": "16"
    },
    "android": {
      "package": "com.kihap.app",
      "versionCode": 16,
      "adaptiveIcon": {
        "backgroundColor": "#eab308",
        "foregroundImage": "./assets/images/android-foreground-fixed.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "meta": {
        "viewport": "width=device-width, initial-scale=1, viewport-fit=cover"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
